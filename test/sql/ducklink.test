# name: test/sql/ducklink.test
# description: the ducklink extension loads and registers its built-in
# group: [ducklink]

# Require ensures the extension is loaded from here on. With no
# DUCKLINK_COMPONENTS set the extension loads and registers zero component
# functions; this asserts the entrypoint runs cleanly and the engine boots.
require ducklink

# The always-available built-in returns the extension version string. Assert the
# SHAPE (the `ducklink ` prefix) rather than an exact version, so this test never
# breaks on a version bump.
query I
SELECT ducklink_version() LIKE 'ducklink %';
----
true
