// DEPRECATED (ducklink 5.0.0) — scheduled for removal at the next
// duckdb:extension major bump. Depends on the deprecated `parser` +
// `parser-dispatch` interfaces; no host drives it.
//
// Parser-extension world (2.3.0 / v3): additionally imports the parser
// registration surface and exports parser-dispatch (the host drives the
// component's `call-parse` from a DuckDB ParserExtension). Built lazily from an
// already-loaded instance. Only parser-capable components satisfy this.
world duckdb-extension-parser {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  import duckdb:extension/parser@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export parser-dispatch;
}

// DEPRECATED (ducklink 5.0.0) — scheduled for removal at the next
// duckdb:extension major bump. Depends on the deprecated `optimizer` +
// `optimizer-dispatch` interfaces; no host drives it.
//
// General-optimizer world (2.3.0 / v3): additionally imports the optimizer-rule
// registration surface and exports optimizer-dispatch (the host offers the
// flattened plan to the component's `call-optimize` from a DuckDB
// OptimizerExtension). Built lazily. Only optimizer-capable components satisfy it.
world duckdb-extension-optimizer {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  import duckdb:extension/optimizer@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export optimizer-dispatch;
}

// OPERATOR extensions are intentionally OUT OF SCOPE for the v3 surface.
// DuckDB's PhysicalOperator/OperatorExtension contract is a by-value, recursive,
// engine-internal pipeline object (state machine over DataChunks with parent/child
// operator pointers) that cannot cross the by-value WIT boundary (the same
// recursion wall that bars a by-value LogicalOperator tree -- see optimizer.wit).
// A component that needs custom physical execution should expose a TABLE FUNCTION
// (streaming, with projection + filter pushdown via table-stream-dispatch) -- that
// is the supported, by-value-safe way to inject a custom scan/producer into a
// plan. No hollow operator interface is shipped.
