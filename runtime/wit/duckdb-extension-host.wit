package duckdb:extension-host;

use duckdb:extension/runtime@4.0.0;
use duckdb:extension/callback-dispatch@4.0.0;
use duckdb:extension/config@4.0.0;
use duckdb:extension/logging@4.0.0;
use duckdb:extension/catalog@4.0.0;
use duckdb:extension/files@4.0.0;
use duckdb:extension/storage@4.0.0;
use duckdb:extension/storage-dispatch@4.0.0;
use duckdb:extension/index@4.0.0;
use duckdb:extension/index-dispatch@4.0.0;
use duckdb:extension/collation@4.0.0;
use duckdb:extension/files-reg@4.0.0;
use duckdb:extension/file-dispatch@4.0.0;
use duckdb:extension/query@4.0.0;
use duckdb:extension/secret@4.0.0;
use duckdb:extension/secret-dispatch@4.0.0;
use duckdb:extension/settings@4.0.0;
use duckdb:extension/macro-ext@4.0.0;
use duckdb:extension/types-ext@4.0.0;
use duckdb:extension/copy-dispatch@4.0.0;
use duckdb:extension/storage-write-dispatch@4.0.0;
// 2.2.0 additive interfaces (Items 6-7).
use duckdb:extension/runtime-ext@4.0.0;
use duckdb:extension/lifecycle@4.0.0;
use duckdb:extension/coordinate-system@4.0.0;
use duckdb:extension/arrow-ext@4.0.0;
use duckdb:extension/encoding@4.0.0;
use duckdb:extension/compression@4.0.0;
use duckdb:extension/table-stream-dispatch@4.0.0;
use duckdb:extension/aggregate-incr-dispatch@4.0.0;
use duckdb:extension/conn-dispatch@4.0.0;
use duckdb:extension/file-write-dispatch@4.0.0;
use duckdb:extension/index-write-dispatch@4.0.0;
use duckdb:extension/settings-dispatch@4.0.0;
// 2.3.0 / v3 additive interfaces: parser + general-optimizer extensions.
use duckdb:extension/parser@4.0.0;
use duckdb:extension/parser-dispatch@4.0.0;
use duckdb:extension/optimizer@4.0.0;
use duckdb:extension/optimizer-dispatch@4.0.0;
// 3.1.0 additive interface: streaming/filter-pushdown table-fn REGISTRATION
// marker (the first additive MINOR off the frozen major-3 baseline).
use duckdb:extension/table-stream@4.0.0;
use duckdb:extension/guest@4.0.0;

// Base extension world: every loadable extension exports these. storage-dispatch
// is NOT mandated here (non-storage extensions like geohash don't export it);
// storage backends are driven through the separate `duckdb-extension-storage`
// world below, instantiated from the SAME component instance on demand. The
// `index` import is satisfied by the host so index-capable components (hnswfns)
// instantiate against this base world; index-dispatch is driven through the
// separate `duckdb-extension-index` world.
world duckdb-extension {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  import duckdb:extension/files-reg@4.0.0;
  // v1.1 live-query host import (catalog completion). The host always PROVIDES it
  // in the extension linker; query-capable components (autocomplete) import it,
  // others don't. Listed here so the host bindings generate the `query::Host`
  // trait + `add_to_linker`.
  import duckdb:extension/query@4.0.0;
  // 2.1.0 additive registration imports: secret types/providers, extension
  // settings/options, table macros, and modified/enum logical types. The host
  // always PROVIDES them; components import only the subset they use.
  import duckdb:extension/secret@4.0.0;
  import duckdb:extension/settings@4.0.0;
  import duckdb:extension/macro-ext@4.0.0;
  import duckdb:extension/types-ext@4.0.0;
  // 2.2.0 additive registration imports (Items 6-7). The host always PROVIDES
  // them; components import only the subset they use.
  import duckdb:extension/runtime-ext@4.0.0;
  import duckdb:extension/lifecycle@4.0.0;
  import duckdb:extension/coordinate-system@4.0.0;
  import duckdb:extension/arrow-ext@4.0.0;
  import duckdb:extension/encoding@4.0.0;
  import duckdb:extension/compression@4.0.0;
  // 2.3.0 / v3 additive registration imports: parser + general-optimizer rule
  // declaration. The host always PROVIDES them; components import only the subset
  // they use (the dispatch side rides the separate parser/optimizer worlds below).
  import duckdb:extension/parser@4.0.0;
  import duckdb:extension/optimizer@4.0.0;
  // 3.1.0 additive registration import: a component declares a streaming/filter-
  // pushdown table function here in load(). The host always PROVIDES it;
  // components import it only if they opt into filter pushdown (the dispatch side
  // rides the separate `duckdb-extension-table-stream` world below). Existing
  // @3.0.0 components do NOT import it and keep loading un-rebuilt.
  import duckdb:extension/table-stream@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
}

// Storage-capable world: additionally exports storage-dispatch. Only storage
// backend components (e.g. sqlitewasm) satisfy this; the runtime instantiates
// its bindings lazily from an already-loaded ExtensionInstance.
world duckdb-extension-storage {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export storage-dispatch;
}

// Index-capable world: additionally exports index-dispatch. Only custom-index
// backend components (e.g. hnswfns) satisfy this; the runtime instantiates its
// bindings lazily from an already-loaded ExtensionInstance.
world duckdb-extension-index {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export index-dispatch;
}

