// Writable-storage world (2.1.0): additionally exports storage-write-dispatch on
// top of the read-only storage-dispatch. Only storage backends that can write
// through satisfy this; the runtime instantiates its bindings lazily.
world duckdb-extension-storage-write {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export storage-dispatch;
  export storage-write-dispatch;
}

// DEPRECATED (ducklink 5.0.0) — scheduled for removal at the next
// duckdb:extension major bump. Depends on the deprecated `table-stream` +
// `table-stream-dispatch` interfaces; no host drives it.
//
// Streaming-table world (2.2.0, Item 6): additionally exports
// table-stream-dispatch. Built lazily from an already-loaded instance.
world duckdb-extension-table-stream {
  import duckdb:extension/runtime@4.0.0;
  import duckdb:extension/config@4.0.0;
  import duckdb:extension/logging@4.0.0;
  import duckdb:extension/catalog@4.0.0;
  import duckdb:extension/files@4.0.0;
  import duckdb:extension/storage@4.0.0;
  import duckdb:extension/index@4.0.0;
  import duckdb:extension/collation@4.0.0;
  // 3.1.0 additive: the filterable-table registration marker, so a streaming
  // component can declare its table fn AND export the dispatch from one instance.
  import duckdb:extension/table-stream@4.0.0;
  export duckdb:extension/guest@4.0.0;
  export callback-dispatch;
  export table-stream-dispatch;
}

