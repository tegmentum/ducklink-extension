package duckdb:extension@4.0.0;

interface catalog {
  use runtime.{cast-callback};

  record logical-type {
    name: string,
    // TODO: narrow this once we know which physical types we support
    physical: string,
  }

  type logical-type-handle = u32;

  enum cast-kind {
    implicit,
    assignment,
    explicit,
  }

  record cast-spec {
    %from: string,
    to: string,
    kind: cast-kind,
    // T2-4 (additive-within-the-record via option arm): DuckDB's cast-function
    // implicit-conversion cost, forwarded to
    // `duckdb_cast_function_set_implicit_cost` at native-registration time.
    //   * `none`        -> use DuckDB's default (100)
    //   * `some(s32)`   -> cost value; `-1` marks the cast explicit-only
    //                       (parity with the C API's convention)
    // Adding an `option` field keeps existing @4.0.0 producers wire-compatible
    // when they leave the field unset — the canonical ABI treats `option<T>`
    // as a variant, so the record grows without renumbering earlier fields.
    implicit-cost: option<s32>,
  }

  record macro-def {
    schema: string,
    name: string,
    parameters: list<string>,
    definition-sql: string,
  }

  /// Register a logical type by name.
  register-logical-type: func(ty: logical-type) -> result<logical-type-handle, string>;

  /// Register a cast between logical types. The callback transforms one source
  /// value into a target value.
  register-cast: func(spec: cast-spec, callback: cast-callback) -> result<_, string>;

  /// Register a default macro.
  register-macro: func(def: macro-def) -> result<_, string>;
}
